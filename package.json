{
  "name": "sacc5i-backend",
  "version": "1.0.0",
  "description": "Backend para Sistema de Atención a la Ciudadanía del C5i",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "predev": "npm run db:migrate",
    "dev": "node --watch src/server.js",
    "server": "node src/server.js",
    "start": "node src/server.js",
    "db:init": "node src/config/initDB.js && npm run db:migrate",
    "seed": "node src/config/seedData.js",
    "db:drop": "node src/config/dropTables.js",
    "db:reset": "npm run db:drop && npm run db:init && npm run seed",
    "db:migrate": "node scripts/ejecutar-migraciones.js",
    "limpiar:tramites": "node scripts/limpiar-tramites.js",
    "limpiar:tramites:usuario": "node scripts/limpiar-tramites-usuario.js"
  },
  "keywords": [
    "sacc5i",
    "backend",
    "express",
    "mysql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.0.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.17.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
